#!/usr/bin/env bash

# ArchSpec — Generador de estructura Jira
# Convierte CONTRATO.md → épicas y user stories para Jira

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PARSE_SCRIPT="$SCRIPT_DIR/parse-contrato.sh"
JIRA_UTILS="$SCRIPT_DIR/lib/jira-project-utils.sh"

# Colores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

source "$PARSE_SCRIPT"
source "$JIRA_UTILS"

print_header() {
    echo -e "${CYAN}${BOLD}"
    echo "════════════════════════════════════════════════════════════════"
    echo "  📊 ArchSpec — Generador de Backlog Jira"
    echo "════════════════════════════════════════════════════════════════"
    echo -e "${RESET}"
}

print_section() {
    echo -e "\n${MAGENTA}${BOLD}━━━ $1 ━━━${RESET}\n" >&2
}

print_success() {
    echo -e "${GREEN}✅ $1${RESET}" >&2
}

print_error() {
    echo -e "${RED}❌ Error: $1${RESET}" >&2
}

print_warning() {
    echo -e "${YELLOW}⚠️  $1${RESET}" >&2
}

print_info() {
    echo -e "${CYAN}ℹ️  $1${RESET}" >&2
}

# ============================================================================
# GENERACIÓN DE ÉPICAS Y STORIES — PROYECTOS LEGACY
# ============================================================================

generate_technical_debt_epic() {
    local project_key="$1"
    local project_dir="$2"
    
    # Buscar archivo de análisis
    local analysis_file="$project_dir/analisis-codigo.json"
    
    local epic_json=$(cat <<EOF
{
  "key": "${project_key}-EPIC-DEBT",
  "name": "Deuda Técnica Identificada",
  "description": "Items de deuda técnica detectados en el análisis automático del código legacy",
  "stories": [
    {
      "title": "Como desarrollador quiero reducir la complejidad ciclomática alta",
      "description": "Refactorizar métodos con complejidad > 10",
      "acceptance_criteria": [
        "Métodos complejos identificados",
        "Complejidad reducida a < 10",
        "Tests agregados"
      ],
      "story_points": 5,
      "priority": "High"
    },
    {
      "title": "Como desarrollador quiero eliminar código duplicado",
      "description": "Extraer lógica duplicada a funciones reutilizables",
      "acceptance_criteria": [
        "Duplicación identificada",
        "Código extraído a helpers/services",
        "Tests agregados"
      ],
      "story_points": 3,
      "priority": "Medium"
    },
    {
      "title": "Como desarrollador quiero actualizar dependencias obsoletas",
      "description": "Actualizar paquetes con versiones antiguas o vulnerabilidades",
      "acceptance_criteria": [
        "Dependencias auditadas",
        "Versiones actualizadas",
        "Compatibilidad verificada"
      ],
      "story_points": 3,
      "priority": "High"
    }
  ]
}
EOF
)
    echo "$epic_json"
}

generate_refactoring_epic() {
    local project_key="$1"
    
    local epic_json=$(cat <<EOF
{
  "key": "${project_key}-EPIC-REFACTOR",
  "name": "Refactoring Arquitectural",
  "description": "Mejoras en la arquitectura y estructura del código legacy",
  "stories": [
    {
      "title": "Como desarrollador quiero separar concerns en el código",
      "description": "Aplicar principios SOLID y separación de responsabilidades",
      "acceptance_criteria": [
        "Controllers delgados (<100 líneas)",
        "Lógica de negocio en Services",
        "Models solo con relaciones y scopes"
      ],
      "story_points": 8,
      "priority": "High"
    },
    {
      "title": "Como desarrollador quiero agregar tests automatizados",
      "description": "Implementar suite de tests para funcionalidad existente",
      "acceptance_criteria": [
        "Unit tests para Services",
        "Integration tests para APIs",
        "Coverage >= 70%"
      ],
      "story_points": 8,
      "priority": "High"
    },
    {
      "title": "Como desarrollador quiero documentar el código",
      "description": "Agregar documentación inline y README técnico",
      "acceptance_criteria": [
        "Docblocks en funciones públicas",
        "README con setup instructions",
        "Diagramas de arquitectura"
      ],
      "story_points": 3,
      "priority": "Medium"
    }
  ]
}
EOF
)
    echo "$epic_json"
}

# ============================================================================
# GENERACIÓN DE ÉPICAS ESPECÍFICAS (ADMIN PANEL + PAGOS)
# ============================================================================

generate_admin_panel_epic() {
    local project_key="$1"
    local contrato_json="$2"
    
    # Verificar si admin panel está habilitado
    local admin_enabled=$(echo "$contrato_json" | jq -r '.features.admin_panel.enabled // false')
    
    if [[ "$admin_enabled" != "true" ]]; then
        echo ""
        return 0
    fi
    
    local admin_level=$(echo "$contrato_json" | jq -r '.features.admin_panel.level // "basico"')
    local roles=$(echo "$contrato_json" | jq -r '.users.roles // "admin, user"')
    
    # Detectar entidades de features.core para generar CRUDs
    local entities=$(echo "$contrato_json" | jq -r '.features.core[]' | head -5)
    
    # Generar user stories según el nivel
    local stories="["
    local first_story=true
    
    # Story 1: Setup básico del admin panel
    stories+=$(cat <<EOF
{
  "title": "Como desarrollador quiero configurar la estructura base del panel de administración",
  "description": "Setup inicial del módulo de administración con autenticación y layout base",
  "acceptance_criteria": [
    "Middleware de autenticación admin configurado",
    "Layout base del panel creado",
    "Rutas protegidas configuradas",
    "Navegación básica implementada"
  ],
  "story_points": 3,
  "priority": "High"
}
EOF
)
    first_story=false
    
    # Story 2: Gestión de usuarios y roles
    if [[ -n "$roles" ]]; then
        stories+=","
        stories+=$(cat <<EOF
{
  "title": "Como admin quiero gestionar usuarios y roles",
  "description": "CRUD completo de usuarios con asignación de roles: $roles",
  "acceptance_criteria": [
    "Listar usuarios con filtros y paginación",
    "Crear/editar usuarios con validación",
    "Asignar roles: $roles",
    "Eliminar usuarios (soft delete)",
    "Tests >= 90%"
  ],
  "story_points": 5,
  "priority": "High"
}
EOF
)
    fi
    
    # Story 3-N: CRUD de entidades detectadas
    while IFS= read -r entity; do
        if [[ -z "$entity" ]]; then
            continue
        fi
        
        stories+=","
        stories+=$(cat <<EOF
{
  "title": "Como admin quiero gestionar $entity",
  "description": "CRUD completo de $entity desde el panel de administración",
  "acceptance_criteria": [
    "Listar $entity con filtros y paginación",
    "Crear/editar $entity con validación",
    "Eliminar $entity (soft delete si aplica)",
    "Búsqueda funcionando",
    "Tests >= 90%"
  ],
  "story_points": 5,
  "priority": "High"
}
EOF
)
    done <<< "$entities"
    
    # Story adicional si nivel es avanzado o completo
    if [[ "$admin_level" == "avanzado" || "$admin_level" == "completo" ]]; then
        stories+=","
        stories+=$(cat <<EOF
{
  "title": "Como admin quiero ver dashboard con métricas del sistema",
  "description": "Dashboard con estadísticas, gráficos y métricas clave",
  "acceptance_criteria": [
    "Métricas clave mostradas (usuarios, entidades, actividad)",
    "Gráficos temporales implementados",
    "Actualización en tiempo real (si aplica)",
    "Exportación de reportes"
  ],
  "story_points": 8,
  "priority": "Medium"
}
EOF
)
    fi
    
    # Story adicional si nivel es completo
    if [[ "$admin_level" == "completo" ]]; then
        stories+=","
        stories+=$(cat <<EOF
{
  "title": "Como admin quiero logs de auditoría del sistema",
  "description": "Sistema de auditoría con registro de acciones críticas",
  "acceptance_criteria": [
    "Logs de cambios en entidades",
    "Logs de acceso admin",
    "Filtros y búsqueda en logs",
    "Retención configurable"
  ],
  "story_points": 5,
  "priority": "Medium"
}
EOF
)
    fi
    
    stories+="]"
    
    # Generar épica completa
    cat <<EOF
{
  "key": "${project_key}-EPIC-ADMIN",
  "name": "Panel de Administración ($admin_level)",
  "description": "Sistema completo de administración con gestión de usuarios, roles y entidades",
  "stories": $stories
}
EOF
}

generate_payments_epic() {
    local project_key="$1"
    local contrato_json="$2"
    
    # Verificar si pagos están habilitados
    local payments_enabled=$(echo "$contrato_json" | jq -r '.features.payments.enabled // false')
    
    if [[ "$payments_enabled" != "true" ]]; then
        echo ""
        return 0
    fi
    
    local providers=$(echo "$contrato_json" | jq -r '.features.payments.providers // "Stripe"')
    
    # Generar user stories por proveedor
    local stories="["
    local first_story=true
    
    # Story 1: Setup básico del sistema de pagos
    stories+=$(cat <<EOF
{
  "title": "Como desarrollador quiero configurar la infraestructura de pagos",
  "description": "Setup inicial del módulo de pagos con base de datos y arquitectura",
  "acceptance_criteria": [
    "Tablas de pagos/transacciones creadas",
    "Modelos y relaciones configurados",
    "Service de pagos base implementado",
    "Logs de transacciones habilitados"
  ],
  "story_points": 3,
  "priority": "High"
}
EOF
)
    
    # Story 2-N: Integración por proveedor
    IFS=',' read -ra PROVIDER_ARRAY <<< "$providers"
    for provider in "${PROVIDER_ARRAY[@]}"; do
        provider=$(echo "$provider" | xargs)  # trim whitespace
        
        if [[ "$first_story" == false ]]; then
            stories+=","
        fi
        first_story=false
        
        stories+=","
        stories+=$(cat <<EOF
{
  "title": "Como usuario quiero pagar con $provider",
  "description": "Integración completa de $provider como método de pago",
  "acceptance_criteria": [
    "SDK de $provider integrado",
    "Flujo de pago funcionando (checkout → confirmación)",
    "Webhooks configurados para estado de pago",
    "Manejo de errores implementado",
    "Tests de integración >= 90%",
    "Cumplimiento PCI-DSS verificado"
  ],
  "story_points": 8,
  "priority": "High"
}
EOF
)
    done
    
    # Story adicional: Panel de gestión de transacciones
    stories+=","
    stories+=$(cat <<EOF
{
  "title": "Como admin quiero ver historial de transacciones",
  "description": "Panel de administración de pagos con historial y filtros",
  "acceptance_criteria": [
    "Listar transacciones con filtros (estado, fecha, monto)",
    "Ver detalles de transacción",
    "Exportar reportes",
    "Reembolsos manuales (si aplica)"
  ],
  "story_points": 5,
  "priority": "Medium"
}
EOF
)
    
    stories+="]"
    
    # Generar épica completa
    cat <<EOF
{
  "key": "${project_key}-EPIC-PAYMENTS",
  "name": "Sistema de Pagos ($providers)",
  "description": "Integración completa de sistema de pagos con proveedores: $providers",
  "stories": $stories
}
EOF
}

# ============================================================================
# GENERACIÓN DE ÉPICAS Y STORIES — PROYECTOS NUEVOS
# ============================================================================

generate_epic_for_feature() {
    local feature_name="$1"
    local project_key="$2"
    local epic_number="$3"
    
    # Normalizar nombre
    local epic_key="${project_key}-EPIC-${epic_number}"
    
    # Descripción genérica basada en el nombre
    local description="Implementación completa del módulo $feature_name"
    
    # Generar JSON épica
    cat <<EOF
{
  "key": "$epic_key",
  "name": "$feature_name",
  "description": "$description",
  "stories": []
}
EOF
}

generate_stories_for_epic() {
    local feature_name="$1"
    local project_key="$2"
    local epic_number="$3"
    
    # Generar 3-5 user stories por épica basadas en el nombre del feature
    # (En producción, esto sería más inteligente usando IA o reglas específicas)
    
    local stories_json="["
    
    # Story 1: Setup básico
    stories_json+=$(cat <<EOF
{
  "title": "Como desarrollador quiero configurar la estructura base de $feature_name",
  "description": "Setup inicial del módulo $feature_name con arquitectura base",
  "acceptance_criteria": [
    "Estructura de directorios creada",
    "Archivos base generados",
    "Tests básicos configurados"
  ],
  "story_points": 2,
  "priority": "High"
}
EOF
)
    
    # Story 2: Funcionalidad core
    stories_json+=","
    stories_json+=$(cat <<EOF
{
  "title": "Como usuario quiero usar $feature_name",
  "description": "Implementación de funcionalidad principal de $feature_name",
  "acceptance_criteria": [
    "Funcionalidad implementada según spec",
    "Validaciones funcionando",
    "Tests unitarios pasando"
  ],
  "story_points": 5,
  "priority": "High"
}
EOF
)
    
    # Story 3: Integración
    stories_json+=","
    stories_json+=$(cat <<EOF
{
  "title": "Como sistema quiero integrar $feature_name con otros módulos",
  "description": "Integración de $feature_name con el resto del sistema",
  "acceptance_criteria": [
    "APIs expuestas",
    "Comunicación entre módulos funcionando",
    "Tests de integración pasando"
  ],
  "story_points": 3,
  "priority": "Medium"
}
EOF
)
    
    # Story 4: UI/UX (si no es backend puro)
    stories_json+=","
    stories_json+=$(cat <<EOF
{
  "title": "Como usuario quiero una interfaz intuitiva para $feature_name",
  "description": "Desarrollo de interfaz de usuario para $feature_name",
  "acceptance_criteria": [
    "Diseño responsive implementado",
    "Feedback visual apropiado",
    "Accesibilidad validada"
  ],
  "story_points": 3,
  "priority": "Medium"
}
EOF
)
    
    stories_json+="]"
    
    echo "$stories_json"
}

generate_backlog() {
    local contrato_file="$1"
    
    print_section "Analizando CONTRATO"
    
    # Detectar si es CONTRATO-LEGACY
    local is_legacy=false
    if [[ "$contrato_file" == *"LEGACY"* ]]; then
        is_legacy=true
        print_info "Proyecto legacy detectado"
    fi
    
    # Parsear CONTRATO
    local contrato_json
    if ! contrato_json=$(parse_contrato "$contrato_file" 2>/dev/null); then
        print_error "No se pudo parsear el CONTRATO"
        return 1
    fi
    
    # Extraer info básica
    local project_name=$(echo "$contrato_json" | jq -r '.project.name')
    local project_display=$(echo "$contrato_json" | jq -r '.project.display_name')
    local project_objective=$(echo "$contrato_json" | jq -r '.identity.objective')
    
    # Generar project key válida de Jira (sin guiones/espacios)
    local project_key
    if ! project_key=$(generate_project_key "$project_name"); then
        print_error "No se pudo generar project key válida"
        return 1
    fi
    
    # Validar project key
    if ! validate_project_key "$project_key"; then
        return 1
    fi
    
    print_info "Proyecto: $project_display"
    print_info "Clave Jira: $project_key"
    
    # Verificar/crear proyecto Jira
    if ! ensure_jira_project_exists "$project_key" "$project_display" "$project_objective"; then
        print_error "No se pudo verificar/crear proyecto Jira $project_key"
        print_info "Crea el proyecto manualmente y vuelve a ejecutar"
        return 1
    fi
    
    # Extraer features core
    local features=$(echo "$contrato_json" | jq -r '.features.core[]')
    local features_count=$(echo "$features" | wc -l | xargs)
    
    print_info "Features detectadas: $features_count"
    echo ""
    
    # Generar épicas y stories
    local backlog_json="{"
    backlog_json+="\"project\": {"
    backlog_json+="\"key\": \"$project_key\","
    backlog_json+="\"name\": \"$project_display\","
    backlog_json+="\"description\": \"$(echo "$contrato_json" | jq -r '.identity.objective')\""
    backlog_json+="},"
    backlog_json+="\"epics\": ["
    
    local epic_number=1
    local first=true
    
    # Si es proyecto legacy, agregar épicas de deuda técnica y refactoring primero
    if [[ "$is_legacy" == true ]]; then
        local project_dir=$(dirname "$contrato_file")
        
        # Épica: Deuda Técnica
        local debt_epic=$(generate_technical_debt_epic "$project_key" "$project_dir")
        backlog_json+="$debt_epic,"
        
        # Épica: Refactoring
        local refactor_epic=$(generate_refactoring_epic "$project_key")
        backlog_json+="$refactor_epic,"
        
        first=false
        epic_number=3
        
        print_info "Épicas legacy agregadas: Deuda Técnica + Refactoring"
    fi
    
    # Generar épicas específicas: Admin Panel + Pagos (proyectos nuevos y legacy)
    local admin_epic=$(generate_admin_panel_epic "$project_key" "$contrato_json")
    if [[ -n "$admin_epic" && "$admin_epic" != "{}" ]]; then
        if [[ "$first" == false ]]; then
            backlog_json+=","
        fi
        first=false
        backlog_json+="$admin_epic"
        print_info "Épica específica agregada: Panel de Administración"
    fi
    
    local payments_epic=$(generate_payments_epic "$project_key" "$contrato_json")
    if [[ -n "$payments_epic" && "$payments_epic" != "{}" ]]; then
        if [[ "$first" == false ]]; then
            backlog_json+=","
        fi
        first=false
        backlog_json+="$payments_epic"
        print_info "Épica específica agregada: Sistema de Pagos"
    fi
    
    while IFS= read -r feature; do
        if [[ -z "$feature" ]]; then
            continue
        fi
        
        if [[ "$first" == false ]]; then
            backlog_json+=","
        fi
        first=false
        
        # Generar épica
        local epic=$(generate_epic_for_feature "$feature" "$project_key" "$epic_number")
        
        # Generar stories para esta épica
        local stories=$(generate_stories_for_epic "$feature" "$project_key" "$epic_number")
        
        # Combinar épica + stories
        local epic_with_stories=$(echo "$epic" | jq ".stories = $stories")
        
        backlog_json+="$epic_with_stories"
        
        epic_number=$((epic_number + 1))
    done <<< "$features"
    
    backlog_json+="]"
    backlog_json+="}"
    
    echo "$backlog_json" | jq '.'
}

# ============================================================================
# PREVIEW
# ============================================================================

show_preview() {
    local backlog_json="$1"
    
    print_section "Vista previa del Backlog"
    
    local project_name=$(echo "$backlog_json" | jq -r '.project.name')
    local project_key=$(echo "$backlog_json" | jq -r '.project.key')
    
    echo -e "${BOLD}Proyecto: $project_name ($project_key)${RESET}"
    echo ""
    
    local epics=$(echo "$backlog_json" | jq -c '.epics[]')
    local epic_count=$(echo "$epics" | wc -l | xargs)
    local total_stories=0
    local total_points=0
    
    while IFS= read -r epic; do
        local epic_name=$(echo "$epic" | jq -r '.name')
        local epic_key=$(echo "$epic" | jq -r '.key')
        local stories=$(echo "$epic" | jq -c '.stories[]')
        local story_count=$(echo "$stories" | wc -l | xargs)
        
        echo -e "${BLUE}${BOLD}ÉPICA: $epic_name${RESET} ($epic_key)"
        
        while IFS= read -r story; do
            local title=$(echo "$story" | jq -r '.title')
            local points=$(echo "$story" | jq -r '.story_points')
            local priority=$(echo "$story" | jq -r '.priority')
            
            local priority_icon="⚪"
            case "$priority" in
                High) priority_icon="🔴" ;;
                Medium) priority_icon="🟡" ;;
                Low) priority_icon="🟢" ;;
            esac
            
            echo -e "  $priority_icon $title ${CYAN}[$points pts]${RESET}"
            
            total_stories=$((total_stories + 1))
            total_points=$((total_points + points))
        done <<< "$stories"
        
        echo ""
    done <<< "$epics"
    
    echo -e "${BOLD}Resumen:${RESET}"
    echo -e "  Épicas: ${BOLD}$epic_count${RESET}"
    echo -e "  User Stories: ${BOLD}$total_stories${RESET}"
    echo -e "  Story Points totales: ${BOLD}$total_points${RESET}"
    echo -e "  Esfuerzo estimado: ${BOLD}~$(( (total_points * 3) / 5 )) días${RESET} (asumiendo ~1.5 pts/día)"
}

# ============================================================================
# MAIN
# ============================================================================

main() {
    local contrato_file="${1:-}"
    
    if [[ -z "$contrato_file" ]]; then
        echo "Uso: $0 <CONTRATO.md>"
        exit 1
    fi
    
    if [[ ! -f "$contrato_file" ]]; then
        print_error "Archivo no encontrado: $contrato_file"
        exit 1
    fi
    
    print_header
    
    # Generar backlog
    local backlog_json
    if ! backlog_json=$(generate_backlog "$contrato_file"); then
        exit 1
    fi
    
    # Guardar JSON
    local project_dir="$(dirname "$contrato_file")"
    local jira_dir="$project_dir/.jira"
    mkdir -p "$jira_dir"
    
    local backlog_file="$jira_dir/backlog.json"
    echo "$backlog_json" > "$backlog_file"
    
    print_success "Backlog generado: $backlog_file"
    echo ""
    
    # Mostrar preview
    show_preview "$backlog_json"
    
    echo ""
    print_info "Para crear los tickets en Jira, usa: archspec planificar"
}

# Ejecutar
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
