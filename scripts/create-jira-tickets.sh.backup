#!/usr/bin/env bash

# ArchSpec — Creador de tickets Jira con confirmación
# Lee backlog.json y crea épicas + stories en Jira vía MCP

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
JIRA_STRUCTURE_SCRIPT="$SCRIPT_DIR/generate-jira-structure.sh"

# Colores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

print_success() {
    echo -e "${GREEN}✅ $1${RESET}"
}

print_error() {
    echo -e "${RED}❌ Error: $1${RESET}"
}

print_warning() {
    echo -e "${YELLOW}⚠️  $1${RESET}"
}

print_info() {
    echo -e "${CYAN}ℹ️  $1${RESET}"
}

# ============================================================================
# INTEGRACIÓN MCP JIRA
# ============================================================================

# Nota: Esta es una implementación stub para fase 2.4
# En producción, esto llamaría al MCP Jira real instalado en ~/.openclaw/workspace/mcp-servers/jira/

create_epic_in_jira() {
    local project_key="$1"
    local epic_name="$2"
    local epic_description="$3"
    
    # Stub: En producción, esto llamaría a MCP Jira
    # Ejemplo: mcp-jira create-epic --project "$project_key" --name "$epic_name"
    
    print_info "Creando épica: $epic_name"
    
    # Simular creación (devolver ID ficticio)
    echo "EPIC-$(date +%s)"
}

create_story_in_jira() {
    local project_key="$1"
    local epic_id="$2"
    local story_title="$3"
    local story_description="$4"
    local story_points="$5"
    local priority="$6"
    
    # Stub: En producción, esto llamaría a MCP Jira
    # Ejemplo: mcp-jira create-issue --type Story --epic "$epic_id" --title "$story_title"
    
    print_info "  └─ Story: $story_title [$story_points pts]"
    
    # Simular creación (devolver ID ficticio)
    echo "STORY-$(date +%s)"
}

# ============================================================================
# CREAR TICKETS DESDE BACKLOG
# ============================================================================

create_tickets_from_backlog() {
    local backlog_file="$1"
    
    if [[ ! -f "$backlog_file" ]]; then
        print_error "Backlog no encontrado: $backlog_file"
        return 1
    fi
    
    local backlog_json=$(cat "$backlog_file")
    local project_key=$(echo "$backlog_json" | jq -r '.project.key')
    
    print_info "Creando tickets en proyecto Jira: $project_key"
    echo ""
    
    local epics=$(echo "$backlog_json" | jq -c '.epics[]')
    local epic_count=0
    local story_count=0
    
    while IFS= read -r epic; do
        local epic_name=$(echo "$epic" | jq -r '.name')
        local epic_desc=$(echo "$epic" | jq -r '.description')
        
        # Crear épica
        local epic_id
        epic_id=$(create_epic_in_jira "$project_key" "$epic_name" "$epic_desc")
        epic_count=$((epic_count + 1))
        
        # Crear stories de esta épica
        local stories=$(echo "$epic" | jq -c '.stories[]')
        
        while IFS= read -r story; do
            local title=$(echo "$story" | jq -r '.title')
            local desc=$(echo "$story" | jq -r '.description')
            local points=$(echo "$story" | jq -r '.story_points')
            local priority=$(echo "$story" | jq -r '.priority')
            
            create_story_in_jira "$project_key" "$epic_id" "$title" "$desc" "$points" "$priority"
            story_count=$((story_count + 1))
        done <<< "$stories"
        
        echo ""
    done <<< "$epics"
    
    print_success "Tickets creados exitosamente"
    print_info "Épicas: $epic_count | Stories: $story_count"
    
    # Devolver metadata
    echo "$epic_count,$story_count"
}

# ============================================================================
# ACTUALIZAR CONTRATO.MD CON METADATA JIRA
# ============================================================================

update_contrato_with_jira_metadata() {
    local contrato_file="$1"
    local epic_count="$2"
    local story_count="$3"
    local project_key="$4"
    
    print_info "Actualizando CONTRATO.md con metadata Jira..."
    
    # Esto requiere yq para editar el YAML frontmatter
    if ! command -v yq &> /dev/null; then
        print_warning "yq no instalado, saltando actualización de CONTRATO.md"
        return 0
    fi
    
    # Actualizar campos Jira en el YAML frontmatter
    yq eval -i ".jira.project_key = \"$project_key\"" "$contrato_file"
    yq eval -i ".jira.epic_count = $epic_count" "$contrato_file"
    yq eval -i ".jira.story_count = $story_count" "$contrato_file"
    yq eval -i ".jira.synced_at = \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"" "$contrato_file"
    
    print_success "CONTRATO.md actualizado"
}

# ============================================================================
# CONFIRMACIÓN USUARIO
# ============================================================================

ask_confirmation() {
    local backlog_file="$1"
    
    # Mostrar preview usando generate-jira-structure.sh
    echo ""
    read -p "¿Crear estos tickets en Jira? [s/N]: " -n 1 -r
    echo
    
    if [[ $REPLY =~ ^[Ss]$ ]]; then
        return 0
    else
        return 1
    fi
}

# ============================================================================
# MAIN
# ============================================================================

main() {
    local contrato_file="${1:-}"
    
    if [[ -z "$contrato_file" ]]; then
        print_error "Uso: $0 <CONTRATO.md>"
        exit 1
    fi
    
    if [[ ! -f "$contrato_file" ]]; then
        print_error "CONTRATO.md no encontrado: $contrato_file"
        exit 1
    fi
    
    local project_dir="$(dirname "$contrato_file")"
    local backlog_file="$project_dir/.jira/backlog.json"
    
    # Generar backlog si no existe
    if [[ ! -f "$backlog_file" ]]; then
        print_info "Generando backlog..."
        if ! bash "$JIRA_STRUCTURE_SCRIPT" "$contrato_file" > /dev/null; then
            print_error "Fallo al generar backlog"
            exit 1
        fi
    fi
    
    # Pedir confirmación
    if ! ask_confirmation "$backlog_file"; then
        print_info "Operación cancelada"
        print_info "Backlog guardado en: $backlog_file"
        print_info "Puedes editarlo manualmente y volver a ejecutar este comando"
        exit 0
    fi
    
    # Crear tickets
    local metadata
    if metadata=$(create_tickets_from_backlog "$backlog_file"); then
        IFS=',' read -r epic_count story_count <<< "$metadata"
        
        # Actualizar CONTRATO.md
        local project_key=$(jq -r '.project.key' "$backlog_file")
        update_contrato_with_jira_metadata "$contrato_file" "$epic_count" "$story_count" "$project_key"
        
        echo ""
        print_success "¡Listo! 🚀"
        print_info "Ver tickets en Jira: https://[tu-dominio].atlassian.net/browse/$project_key"
    else
        print_error "Fallo al crear tickets"
        exit 1
    fi
}

# Ejecutar
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
